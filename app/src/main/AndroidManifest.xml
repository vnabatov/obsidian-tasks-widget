<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE" />
    <uses-permission android:name="android.permission.WRITE_EXTERNAL_STORAGE" />
    <uses-permission android:name="android.permission.MANAGE_EXTERNAL_STORAGE" />

    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:supportsRtl="true"
        android:theme="@style/Theme.TaskWidget"
        android:requestLegacyExternalStorage="true">

        <!-- Main config activity -->
        <activity
            android:name=".ConfigActivity"
            android:exported="true"
            android:label="@string/app_name"
            android:theme="@style/Theme.TaskWidget">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Widget configuration activity -->
        <activity
            android:name=".WidgetConfigActivity"
            android:exported="false"
            android:theme="@style/Theme.TaskWidget">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_CONFIGURE" />
            </intent-filter>
        </activity>

        <!-- Widget provider -->
        <receiver
            android:name=".TaskWidgetProvider"
            android:exported="true">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
                <action android:name="com.taskwidget.app.ACTION_REFRESH" />
                <action android:name="com.taskwidget.app.ACTION_COMPLETE" />
                <action android:name="com.taskwidget.app.ACTION_OPEN_OBSIDIAN" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/task_widget_info" />
        </receiver>

        <!-- Widget list service -->
        <service
            android:name=".TaskWidgetService"
            android:permission="android.permission.BIND_REMOTEVIEWS"
            android:exported="false" />

    </application>
</manifest>
